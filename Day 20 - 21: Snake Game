# Constants: Starting position is a constant should be in capitals.
'''
Constants in python are variables whose values are meant to remain unchanged throughout the life of a program.
Constants are usally defined in all uppercase lettes with underscore(_) between words.
They are typically placed at the top of the file.
'''
from turtle import Turtle, Screen
import time
import random

screen = Screen()
screen.title("Development Mode")
screen.setup(width = 600, height = 600)
screen.bgcolor("black")
screen.tracer(0)
STARTING_POSITION = [(0,0),(-20,0),(-40,0)]
MOVE_DISTANCE = 20

class Snake:
    def __init__(self):
        self.segments = [] # Empty List
        self.create_snake()
        self.head = self.segments[0]

    def create_snake(self):
        for position in STARTING_POSITION:
            new_segment = Turtle()
            new_segment.shape("square")
            new_segment.color("white")
            new_segment.penup()
            new_segment.goto(position)
            self.segments.append(new_segment)
   
    def move(self):
        for seg_num in range(len(self.segments) -1, 0, -1):
            new_x = self.segments[seg_num -1].xcor()
            new_y = self.segments[seg_num -1].ycor()
            self.segments[seg_num].goto(new_x, new_y)
        self.segments[0].forward(MOVE_DISTANCE)

    def up(self):
        self.segments[0].setheading(90)
        self.head.setheading(UP)

    def down(self):
        self.segments[0].setheading(270)
        self.head.setheading(DOWN)

    def left(self):
        self.segments[0].setheading(180)
        self.setheading(LEFT)

    def right(self):
        self.segments[0].setheading(0)
        self.setheading(RIGHT)

class Food(Turtle):
    def __init__ (self):
        super().__init__()
        self.shape("circle")
        self.penup()
        self.shapesize(stretch_len = 0.5, stretch_wid = 0.5)
        self.color("blue")
        self.speed(10)
        random_x = random.randint(-200, 200)
        random_y = random.randint(-200, 200)
        self.goto(random_x, random_y)

snake = Snake()
food = Food()

#Key board bindings
screen.listen()
screen.onkey(snake.up, "Up")
screen.onkey(snake.left, "Left")
screen.onkey(snake.down, "Down")
screen.onkey(snake.right, "Right")

game_is_on = True
while game_is_on:
    screen.update()
    time.sleep(0.1)
    snake.move()

screen.exitonclick()
